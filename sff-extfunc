EDITOR=${EDITOR:-vi}
PWD=${PWD:-$(pwd)}
sffpipe="$2"
sffdir=${sffpipe%/*}

exbuf1="${sffdir}/.exec-buf1"
exbuf2="${sffdir}/.exec-buf2"
lastop="${sffdir}/.last-operation"
cpbuf="${sffdir}/.copy-buf"
tsel="${sffdir}/.tmpsel"
tbuf1="${sffdir}/.tmpbuf1"
tbuf2="${sffdir}/.tmpbuf2"

err=''
unset LESS
[ ! -p "$sffpipe" ] && exit 0

# === sff extension functions ===

sffpipe_clear_sel()
{
	printf "." >"$sffpipe"
}

sffpipe_refresh()
{
	[ "$1" = '-c' ] && printf "*." >"$sffpipe" \
	|| printf "*" >"$sffpipe"
}

sffpipe_sel_file()
{
	local name="$1"
	[ "$1" = "$exbuf1" -o "$1" = "$exbuf2" ] \
	&& name=$(tr '\n\0' '\035\n' <"$1" | head -n 1 | tr -d '\n' | tr '\035' '\n')
	printf "@%s\0" "$name" >"$sffpipe"
}

sffpipe_enter()
{
	printf ">%s\0" "$1" >"$sffpipe"
}

sffpipe_get_sel()
{
	printf "%s" "$$" >"$sffpipe"
	sel="$sffpipe"
}

sff_init_bufs()
{
	[ -e "$exbuf1" ] && [ -e "$exbuf2" ] && [ -e "$lastop" ] && [ -e "$cpbuf" ] && return 0
	touch -a "$exbuf1" "$exbuf2" "$lastop" "$cpbuf"
	chmod 600 "$exbuf1" "$exbuf2" "$lastop" "$cpbuf"

	if [ ! -O "$sffdir" ]; then
		stat --version >/dev/null 2>&1 \
		&& local uid=$(stat -c %u "$sffdir") \
		|| local uid=$(stat -f %u "$sffdir")
		chown "$uid" "$exbuf1" "$exbuf2" "$lastop" "$cpbuf"
	fi
}

sff_abort()
{
	rm -f "$tsel" "$tbuf1" "$tbuf2"
	[ "$1" ] && rm -f "$1"
	: >"$lastop"
	exit 0
}

sff_pwd_perm()
{
	if [ ! -w "$PWD" ]; then
		printf "\n%s: Permission denied\n" "$PWD"
		read -p "Press Enter to continue " -r x
		exit 0
	fi
}

sff_new()
{
	sff_pwd_perm
	sff_init_bufs
	local tlist="${sffdir}/.Create-Files"
	rm -f "$tlist" "$tbuf1" "$tbuf2"

	while true; do
		"$EDITOR" "$tlist"
		[ -e "$tlist" ] && sed -e 's/^\/*//' -e 's/[ \t]*$//' -e '/^$/d' "$tlist" >"$tbuf1"
		[ ! -s "$tbuf1" ] && sff_abort "$tlist"

		sed -e 's/\/.*$//' "$tbuf1" | sort -u >"$tbuf2"
		local dlin=$(xargs ls -1d -- 2>/dev/null <"$tbuf2" | head -n 80)
		[ -z "$dlin" ] && break

		printf "\n%s\n" "$dlin"
		echo "^^^: File(s) already exist"
		echo "e) edit the list"
		echo "q) abort"
		read -p "(e/q) [default=e]: " -r x
		[ "$x" = 'q' ] && sff_abort "$tlist"
	done

	sed -e "s^$PWD/" "$tbuf2" | tr '\n' '\0' >"$exbuf2"
	sed -e '/\//!d' -e 's/\/[^/]*$//' -e "s^$PWD/" "$tbuf1" | sort -u | tr '\n' '\0' >"$exbuf1"
	printf "\037" >>"$exbuf1"
	sed -e '/\/$/d' -e "s^$PWD/" "$tbuf1" | tr '\n' '\0' >>"$exbuf1"

	rm -f "$tlist" "$tbuf1" "$tbuf2"
	sff_do_new
}

sff_do_new()
{
	printf "new" >"$lastop"
	sffpipe_sel_file "$exbuf2"

	cut -d '' -f1 "$exbuf1" | tr -d '\n' | xargs -r -0 mkdir -p -- || err=1
	cut -d '' -f2 "$exbuf1" | tr -d '\n' | xargs -r -0 touch -- || err=1
	[ "$err" ] && read -p "Press Enter to continue " -r x
}

sff_undo_new()
{
	[ ! -s "$exbuf2" ] && exit 0
	local op=$(cat "$lastop")

	echo ""
	tr '\0' '\n' <"$exbuf2" | head -n 160
	echo "^^^:" $(tr '\n\0' '\035\n' <"$exbuf2" | wc -l) "file(s) will be permanently deleted!"
	read -p "Undo '${op}' operation? (y/n) [default=n]: " -r x
	[ "$x" != 'y' ] && exit 0

	printf "un%s" "$op" >"$lastop"
	sffpipe_refresh

	xargs -0 rm -rf -- <"$exbuf2" || err=1
	[ "$err" ] && read -p "Press Enter to continue " -r x
}

sff_write_cbuf()
{
	sff_init_bufs
	sffpipe_get_sel
	tr '\n\0' '\035\n' <"$sel" >"$cpbuf"
	[ "$1" = 'mv' ] && chmod u+s "$cpbuf"
	sffpipe_clear_sel
}

sff_view_cbuf()
{
	echo ""
	if [ -s "$cpbuf" ]; then
		head -n 160 "$cpbuf"
		echo $(wc -l <"$cpbuf") "file(s) in buffer"
	else
		echo "Buffer is empty"
	fi
	read -p "Press Enter to continue " -r x
}

sff_clear_cbuf()
{
	[ -s "$cpbuf" ] && : >"$cpbuf"
}

sff_paste()
{
	[ ! -s "$cpbuf" ] && exit 0
	[ "$(find "$cpbuf" -mmin +30)" ] && exit 0
	sff_pwd_perm

	local x='' op='copy'
	ls -l "$cpbuf" | grep -q '^...[sS]' && op='move' && chmod u-s "$cpbuf"

	local dlin=$(sed 's/^.*\///' "$cpbuf" | tr '\n\035' '\0\n' | xargs -0 ls -1d -- 2>/dev/null | head -n 80)
	if [ "$dlin" ]; then
		printf "\n%s\n" "$dlin"
		echo "^^^: File(s) already exist"
		echo "s) skip all (cannot be undone)"
		echo "i) prompt before overwrite (cannot be undone)"
		echo "w) overwrite all (cannot be undone)"
		echo "q) abort"
		read -p "(s/i/w/q) [default=q]: " -r x
		[ "${x%[siw]}" -o ! "$x" ] && sff_abort
	fi

	sed -e "s$\n$PWD/" "$cpbuf" | tr '\n\035' '\0\n' >"$exbuf1"

	case "$op" in
	'copy') sed "s^.*/$PWD/" "$cpbuf" | tr '\n\035' '\0\n' >"$exbuf2"
		[ "$1" ] && : >"$cpbuf";;
	'move') sed "s^.*/$PWD/" "$cpbuf" | paste -d '' - "$cpbuf" | tr '\037\n\035' '\0\0\n' >"$exbuf2"
		: >"$cpbuf";;
	esac

	x=${x:-'0'}
	sff_do_paste "$op" "$x"
}

sff_do_paste()
{
	printf "%s" "$1" >"$lastop"
	[ "$2" != '0' ] && touch -mt 202310011200.00 "$lastop"
	sffpipe_sel_file "$exbuf2"

	case "$1" in
	'copy') case "$2" in
		'0'|'w') xargs -0 -n 2 cp -afv -- <"$exbuf1" || err=1;;
		's') xargs -0 -n 2 cp -anv -- <"$exbuf1" || err=1;;
		'i') xargs -0 -n 2 -o cp -aiv -- <"$exbuf1" || err=1;;
		esac
		;;
	'move') case "$2" in
		'0'|'w') xargs -0 -n 2 mv -fv -- <"$exbuf1" || err=1;;
		's') xargs -0 -n 2 mv -nv -- <"$exbuf1" || err=1;;
		'i') xargs -0 -n 2 -o mv -iv -- <"$exbuf1" || err=1;;
		esac
		;;
	esac
	[ "$err" ] && read -p "Press Enter to continue " -r x
}

sff_rename()
{
	sff_init_bufs
	sffpipe_get_sel
	rm -f "$tsel" "$tlist" "$tbuf1" "$tbuf2"
	tr '\n\0' '\035\n' <"$sel" >"$tsel"
	[ ! -s "$tsel" ] && exit 0

	sed 's/\/[^/]*$//' "$tsel" >"$tbuf1"
	local tlist="${sffdir}/.Rename"
	[ $(sort -u "$tbuf1" | wc -l | tr -d ' ') = 1 ] \
	&& sed 's/^.*\///' "$tsel" >"$tlist" || cat "$tsel" >"$tlist"

	while true; do
		"$EDITOR" "$tlist"
		sed -e 's/^.*\///' -e 's/^[ \t]*$//' "$tlist" | paste -d '/' "$tsel" "$tbuf1" - \
		| sed -e '/^\(.*\)\1$/d' -e '/^/d' -e '/\/$/d' >"$tbuf2"
		[ ! -s "$tbuf2" ] && sff_abort "$tlist"

		local dlin1=$(cut -d '' -f 2 "$tbuf2" | sort | uniq -d | head -n 80)
		[ "$dlin1" ] && printf "\n%s\n^^^: The list has duplicate names\n" "$dlin1"

		local dlin2=$(cut -d '' -f 2 "$tbuf2" | tr '\n\035' '\0\n' | xargs -0 ls -1d -- 2>/dev/null | head -n 80)
		[ "$dlin2" ] && printf "\n%s\n^^^: File(s) already exist\n" "$dlin2"

		[ -z "$dlin1" ] && [ -z "$dlin2" ] && break
		echo "e) edit the list"
		echo "q) abort"
		read -p "(e/q) [default=e]: " -r x
		[ "$x" = 'q' ] && sff_abort "$tlist"
	done

	tr '\037\n\035' '\0\0\n' <"$tbuf2" >"$exbuf1"
	sed 's/\(.*\)\(.*\)/\2\1/' "$tbuf2" | tr '\037\n\035' '\0\0\n' >"$exbuf2"

	rm -f "$tsel" "$tlist" "$tbuf1" "$tbuf2"
	sff_do_rename
}

sff_do_rename()
{
	printf "rename" >"$lastop"
	sffpipe_sel_file "$exbuf2"

	xargs -0 -n 2 mv -nv -- <"$exbuf1" || err=1
	[ "$err" ] && read -p "Press Enter to continue " -r x
}

sff_undo_move()
{
	[ ! -s "$exbuf2" ] && exit 0
	local op=$(cat "$lastop")
	echo ""
	xargs -0 -n 2 printf "%s -> %s\n" <"$exbuf2" | head -n 160
	read -p "Undo '$op' operation? (y/n) [default=n]: " -r x
	[ "$x" != 'y' ] && exit 0

	printf "un%s" "$op" >"$lastop"
	sffpipe_sel_file "$exbuf1"

	xargs -0 -n 2 mv -n -- <"$exbuf2" || err=1
	[ "$err" ] && read -p "Press Enter to continue " -r x
}

sff_duplicate()
{
	sff_init_bufs
	sffpipe_get_sel
	rm -f "$tsel"; tr '\n\0' '\035\n' <"$sel" >"$tsel"
	[ ! -s "$tsel" ] && exit 0

	printf "\nEnter the number of copies ('q' to cancel)\n"
	read -p "(number/q) [default=1]: " -r x
	x=${x%${x##*[![:space:]]}}
	x=$(printf "%s" "${x:-'1'}" | tr -cd '0-9')
	x=${x#${x%%[!0]*}}
	[ -z "$x" ] && exit 0

	local num pa npa k
	: >"$exbuf1"; : >"$exbuf2"
	while IFS='' read -r pa; do
		num=1
		pa=$(printf "%s" "$pa" | tr '\035' '\n')

		for i in $(seq "$x"); do
			npa="${pa}_$num"
			k=$num
			while [ -e "$npa" ]; do
				k=$((k+1))
				npa="${pa}_$k"
			done
			num=$((k+1))

			printf "%s\0%s\0" "$pa" "$npa" >>"$exbuf1"
			printf "%s\0" "$npa" >>"$exbuf2"
		done
	done <"$tsel"
	rm -f "$tsel"

	[ ! -s "$exbuf1" ] && sff_abort
	sff_do_duplicate
}

sff_do_duplicate()
{
	printf "duplicate" >"$lastop"
	sffpipe_sel_file "$exbuf2"

	xargs -0 -n 2 cp -an -- <"$exbuf1" || err=1
	[ "$err" ] && read -p "Press Enter to continue " -r x
}

sff_delete()
{
	sffpipe_get_sel
	rm -f "$tsel"; tr '\n\0' '\035\n' <"$sel" >"$tsel"
	[ ! -s "$tsel" ] && exit 0

	echo ""
	head -n 160 "$tsel"
	echo "Permanently delete" $(wc -l <"$tsel") "file(s), this action cannot be undone"
	read -p "Are you sure? (y/n) [default=n]: " -r x
	[ "$x" != 'y' ] && exit 0
	sffpipe_refresh -c

	tr '\n\035' '\0\n' <"$tsel" | xargs -0 rm -rf -- || err=1
	rm -f "$tsel"
	[ "$err" ] && read -p "Press Enter to continue " -r x
}

sff_chmod_chown()
{
	printf "\nEnter permissions (e.g., 644, a+x) or owner and group (e.g., cat:wheel)\n"
	echo "Add -R at the beginning to apply changes recursively"
	echo "Press Enter to cancel"
	read -p ": " -r x
	x=${x%${x##*[![:space:]]}}
	[ -z "$x" ] && exit 0

	sffpipe_get_sel
	case "$x" in
	*:*) xargs -r -0 chown $x <"$sel" || err=1;;
	*) xargs -r -0 chmod $x <"$sel" || err=1;;
	esac
	sffpipe_refresh
	[ "$err" ] && read -p "Press Enter to continue " -r x
}

sff_find()
{
	printf "\nType a name pattern or press Enter to cancel\n"
	read -p "find ./ -name " -r x
	[ -z "$x" ] && exit 0

	echo "Optionally, add more options (e.g., -type d, -size +4k)"
	read -p ": " -r y
	echo "Searching in $PWD/ ..."

	{ printf "?"; find ./ $y -name "$x" 2>/dev/null | sed -e 's/^\.\///' | tr '\n' '\0'; } >"$sffpipe"
}

sff_file_stat()
{
	sffpipe_get_sel
	rm -f "$tsel"; tr '\n\0' '\035\n' <"$sel" >"$tsel"
	[ ! -s "$tsel" ] && { rm -f "$tsel"; exit 0; }

	local f
	while IFS='' read -r f; do
		echo ""
		f="$(printf "%s" "$f" | tr '\035' '\n')"
		stat --version >/dev/null 2>&1 && stat "$f" || stat -x "$f"
		file -bi "$f"
		file -b "$f"
	done <"$tsel"
	rm -f "$tsel"
	read -p "Press Enter to continue " -r x
}

sff_disk_usage()
{
	sffpipe_get_sel
	echo ""
	xargs -r -0 du -shc -- <"$sel" | sort -h
	echo ""
	df -h "$PWD"
	read -p "Press Enter to continue " -r x
}

sff_undo()
{
	[ ! -s "$lastop" ] && exit 0
	[ "$(find "$lastop" -mmin +360)" ] && exit 0

	case "$(cat "$lastop")" in
	'new'|'copy'|'duplicate') sff_undo_new;;
	'move'|'rename') sff_undo_move;;
	esac
}

sff_redo()
{
	[ ! -s "$lastop" ] && exit 0

	case "$(cat "$lastop")" in
	'unnew') sff_do_new;;
	'uncopy') sff_do_paste 'copy' '0';;
	'unmove') sff_do_paste 'move' '0';;
	'unrename') sff_do_rename;;
	'unduplicate') sff_do_duplicate;;
	esac
}

sff_help()
{
	sed -n '/[ ][#][?][>][ ]/p' "$0" | sed 's/^.*[#][?][>]//' | less
}

run_pl()
{
	plugin="${sffdir}/plugins/$1"
	[ ! -e "$plugin" ] && plugin="${0%/*}/plugins/$1"
	if [ ! -e "$plugin" ]; then
		printf "\nPlugin '%s' not found\n" "$1"
		read -p "Press Enter to continue " -r x
	else
		"$plugin" "$sffpipe" "$2"
	fi
}

# === custom functions ===


# === key bindings ===
case "$1" in                  #?> Extension functions:
'n') sff_new;;                #?>     Alt-n  Create new files (ends with '/' for dirs)
'd') sff_delete;;             #?>     Alt-d  Delete
'y') sff_write_cbuf 'cp';;    #?>     Alt-y  Copy
'x') sff_write_cbuf 'mv';;    #?>     Alt-x  Cut
'v') sff_view_cbuf;;          #?>     Alt-v  View copy/cut buffer
'V') sff_clear_cbuf;;         #?>     Alt-V  Clear copy/cut buffer
'p') sff_paste 'd';;          #?>     Alt-p  Paste
'P') sff_paste;;              #?>     Alt-P  Paste and keep copy buffer
'r') sff_rename;;             #?>     Alt-r  Rename
'Y') sff_duplicate;;          #?>     Alt-Y  Duplicate
'm') sff_chmod_chown;;        #?>     Alt-m  Change permissions or owner
'f') sff_find;;               #?>     Alt-f  Advanced search
'i') sff_file_stat;;          #?>     Alt-i  Show file status
'I') sff_disk_usage;;         #?>     Alt-I  Show disk usage
'u') sff_undo;;               #?>     Alt-u  Undo last operation
'U') sff_redo;;               #?>     Alt-U  Redu last operation
'/') sff_help;;               #?>     Alt-/  Show this help
                              #?> Plugins:
'F') run_pl 'fzf-find';;      #?>     Alt-F  Search with 'fzf'
'=') run_pl 'preview' 'tui';; #?>     Alt-=  Toggle preview
'z') run_pl 'archive' 'e';;   #?>     Alt-z  Extract archives
'Z') run_pl 'archive' 'c';;   #?>     Alt-Z  Create archive
esac                          #?> Press 'q' to leave this page.
