#!/usr/bin/env sh

# Description: Extract and create archives
#
# Supported creation:
#   bz2, gz, tar (with gz, bz2, xz), xz, zip, 7z
#
# Supported extraction:
#    ar, arj, bz2, cab, chm, cpio, cramfs, deb, dmg, gz, iso, lzh, lzma,
#    msi, nsis, qcow2, rar, rpm, squashfs, tar (with gz, bz2, xz), wim,
#    xar, xz, zip, Z, 7z
#
# Dependencies:
#   - tar, gzip, bzip2, xz
#   - 7zip
#
# Shell: POSIX compliant
#
# Author: Shi Yanling

sffpipe=$1
sffdir=${sffpipe%/*}
tmpdir=${TMPDIR:-/tmp}
[ ! -w "$tmpdir" ] && tmpdir=$sffdir
uid=$(id -u)
tsel="${tmpdir}/sff-tmpsel-$uid"
tbuf1="${tmpdir}/sff-tmpbuf2-$uid"

sffpipe_sel_file()
{
	printf "@%s\0" "$1" >"$sffpipe"
}

sffpipe_get_sel()
{
	printf "%s" "$$" >"$sffpipe"
	sel=$sffpipe
}

extract_archive()
{
	sffpipe_get_sel
	tr '\n\0' '\035\n' <"$sel" >"$tsel"
	[ ! -s "$tsel" ] && return 0

	printf "\n(l)ist contents / (e)xtract / (c)ancel [l]: "; read -r _x
	[ "$_x" = 'c' ] && return 0

	_err=''
	_selfile=''
	while IFS='' read -r _path <&3; do
		_path=$(printf "%s" "$_path" | tr '\035' '\n')
		_wdir=${_path%/*}
		_name=${_path##*/}
		_bname=${_name%.?*}
		_bname=${_bname%.tar}

		case "$_x" in
		'e') if [ -e "${_wdir}/$_bname" ]; then
				printf "\n'%s' exists. Overwrite? (y/n) [n]: " "$_bname"; read -r _y
				[ "$_y" != 'y' ] && continue
			fi
	 		_tdir=$(mktemp -d "${_wdir}/tmp.XXXXXX")
			[ -e "${_wdir}/$_bname" ] && rm -rf "${_wdir}/$_bname"

			echo "Extracting..."
			case "$(printf "%s" "$_name" | tr 'A-Z' 'a-z')" in
			*?.tar.?*) cd "$_tdir" && tar -xvf "$_path";;
			*?.gz) gunzip -k "$_path";;
			*?.bz2) bunzip2 -k "$_path";;
			*?.xz) unxz -k "$_path";;
			*?.?*) cd "$_tdir" && { tar -xvf "$_path" || 7zz x -aoa "$_path"; };;
			esac || _err=1

			_num=$(find "$_tdir"/ -mindepth 1 -maxdepth 1 ! -name . ! -name .. -exec echo '1' \; | wc -l)
			if [ -d "${_tdir}/$_bname" ] && [ "$_num" -eq 1 ]; then
				mv "${_tdir}/$_bname" "$_wdir"/
			elif [ ! -e "${_wdir}/$_bname" ]; then
				mv "$_tdir" "${_wdir}/$_bname"
			fi
			[ -e "$_tdir" ] && rm -rf "$_tdir"
			[ -z "$_err" ] && _selfile="$_bname"
			;;

		*) echo ""
			case "$(printf "%s" "$_name" | tr 'A-Z' 'a-z')" in
			*?.tar.?*) tar -tvf "$_path";;
			*?.gz) zcat "$_path";;
			*?.bz2) bzcat "$_path";;
			*?.xz) xzcat "$_path";;
			*?.?*) tar -tvf "$_path" 2>/dev/null || 7zz l "$_path";;
			esac
			printf "Press Enter to continue "; read -r _x
			;;
		esac
	done 3<"$tsel"

	[ "$_selfile" ] && sffpipe_sel_file "$_selfile"
	[ "$_err" ] && { printf "Press Enter to continue "; read -r _x; }
}

create_archive()
{
	sffpipe_get_sel
	tr '\n\0' '\035\n' <"$sel" >"$tsel"
	[ ! -s "$tsel" ] && return 0

	while true; do
		printf "\nArchive name (empty to cancel): "; read -r _name
		[ -z "$_name" ] && return 0
		if [ -e "$_name" ]; then
			printf "\n'%s' exists. Overwrite? (y/n) [n]: " "$_name"; read -r _x
			[ "$_x" = 'y' ] && break
		else
			break
		fi
	done

	_wdir=$(printf "%s" "$PWD" | tr '\n' '\035')
	sed "s^$_wdir/" "$tsel" | tr '\n\035' '\0\n' >"$tbuf1"
	[ -e "$_name" ] && rm -f "$_name"

	case "$(printf "%s" "$_name" | tr 'A-Z' 'a-z')" in
	*?.tar.?*|*?.t?*) xargs -0 tar -cavf "$_name" -- <"$tbuf1";;
	*.gz) xargs -0 gzip -fk -- <"$tbuf1";;
	*.bz2) xargs -0 bzip2 -fk -- <"$tbuf1";;
	*.xz) xargs -0 xz -fk -- <"$tbuf1";;
	*?.7z|*?.zip) xargs -0 7zz a "$_name" -- <"$tbuf1";;
	*) printf "\nUnsupported archive format\n"; false;;
	esac

	if [ "$?" -eq 0 ]; then
		 sffpipe_sel_file "$_name"
	else
		printf "Press Enter to continue "; read -r _x
	fi
}

case "$2" in
'e') extract_archive;;
'c') create_archive;;
esac
rm -f "$tsel" "$tbuf1"
